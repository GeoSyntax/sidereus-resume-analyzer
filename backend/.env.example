APP_ENV=local
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5500,http://localhost:8000
MAX_UPLOAD_MB=8
CACHE_TTL_SECONDS=86400

# Optional. If not set, the service uses deterministic rule-based extraction/scoring.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Optional. If not set or unavailable, the service falls back to in-process memory cache.
REDIS_URL=

